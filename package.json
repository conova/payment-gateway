{
  "name": "payment-gateway",
  "version": "0.1.0",
  "description": "Payment gateway microservice — NEGDI ecommerce merchant integration",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "@fastify/sensible": "^6.0.1",
    "@fastify/cors": "^10.0.1",
    "oracledb": "^6.7.0",
    "undici": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8",
    "dotenv": "^16.4.7",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/oracledb": "^6.5.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}
