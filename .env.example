# ─── HTTP server ───
PORT=3002
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── Oracle DB ───
ORACLE_USER=payment_gateway
ORACLE_PASSWORD=change_me
ORACLE_CONNECT_STRING=localhost:1521/XEPDB1
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10

# ─── NEGDI Ecommerce ───
# Base URL — production-д http://.../api/pay (NEGDI-аас өгсөн)
NEGDI_BASE_URL=http://103.229.177.11:8032/api/pay
# Terminal credentials — NEGDI-аас өгөгдсөн
NEGDI_TERMINAL_ID=1
NEGDI_USERNAME=user
NEGDI_PASSWORD=secretword
# 3DS / non-3DS төлбөрийн дараа хэрэглэгчийг нэн буцаах URL (mobile-ийн deep link)
NEGDI_RETURN_URL=mandalcapital://payment/callback
# Default theme + language
NEGDI_DEFAULT_THEME=W
NEGDI_DEFAULT_LANG=mn
# NEGDI signature verification — багц дотроос default-аар уншина
# (өөрчилгөө байх тохиолдолд NEGDI_PUBLIC_KEY-аар override хийх боломжтой)
# NEGDI_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----..."

# ─── Auth ───
CORE_API_KEY=replace-with-long-random-string-min-32-chars
ADMIN_API_KEY=another-long-random-string-for-admin-endpoints

JWT_SECRET=shared-with-core-system-jwt-secret
JWT_ISSUER=bds.techfi.mn

# HTTP client timeout to NEGDI (ms)
NEGDI_TIMEOUT_MS=15000
